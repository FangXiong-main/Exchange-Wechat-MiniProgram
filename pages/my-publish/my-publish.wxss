/* ========== 全屏液态玻璃加载 ========== */
.loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  
  .loading-glass {
    padding: 50rpx 80rpx;
    border-radius: 20rpx;
    background: rgba(255,255,255,0.25);
    border: 1px solid rgba(255,255,255,0.3);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
  }
  
  .loading-text {
    font-size: 32rpx;
    color: #2d8cf0;
    font-weight: bold;
  }
  
  /* ========== 原有样式 ========== */
  page {
    background: #f5fafe;
  }
  text {
    display: inline-block;
    line-height: 1;
    margin: 0 !important;
    padding: 0 !important;
  }
  
  .glass-bg {
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
    backdrop-filter: blur(20px);
    min-height: 100vh;
    padding: 30rpx;
    box-sizing: border-box;
  }
  .glass-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(25px);
    border: 1rpx solid rgba(255,255,255,0.3);
    border-radius: 20rpx;
  }
  
  .list-box {
    display: flex;
    flex-direction: column;
    gap: 24rpx;
  }
  .list-item {
    display: flex;
    padding: 30rpx;
    align-items: center;
  }
  .item-img {
    width: 150rpx;
    height: 150rpx;
    border-radius: 16rpx;
    margin-right: 28rpx;
  }
  
  .item-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12rpx;
  }
  .item-name {
    font-size: 30rpx;
    color: #333;
    line-height: 1.4;
  }
  .item-price {
    font-size: 32rpx;
    color: #fa5555;
    font-weight: bold;
  }
  
  .status-wrap {
    display: flex;
    align-items: center;
    height: 28rpx;
    line-height: 28rpx;
  }
  .dot {
    width: 16rpx;
    height: 16rpx;
    border-radius: 50%;
    margin-right: 10rpx;
    flex-shrink: 0;
    display: block;
  }
  .dot.green { background: #00c48c; }
  .dot.red { background: #fa5555; }
  .status-text {
    font-size: 24rpx;
    color: #666;
    line-height: 28rpx;
    height: 28rpx;
    display: inline-block;
    vertical-align: middle;
  }
  
  .date {
    font-size: 22rpx;
    color: #999;
  }
  
  .empty-box {
    height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .empty-card {
    padding: 70rpx 50rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .empty-icon {
    font-size: 80rpx;
    margin-bottom: 20rpx;
  }
  .empty-text {
    color: #999;
    font-size: 28rpx;
  }
  
  .load-tip {
    text-align: center;
    padding: 20rpx 0;
    color: #999;
  }