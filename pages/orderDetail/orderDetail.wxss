/* 加载动画 */
.loading-overlay {
    position: fixed; 
    top: 0; 
    left: 0; 
    width: 100%; 
    height: 100%;
    z-index: 9999; 
    display: flex; 
    align-items: center; 
    justify-content: center;
    background: rgba(255,255,255,0.15); 
    -webkit-backdrop-filter: blur(12rpx);
    backdrop-filter: blur(12rpx);
  }
  .loading-glass { 
    padding: 50rpx 80rpx; 
    border-radius: 24rpx; 
    background: rgba(255,255,255,0.3); 
    border: 1rpx solid rgba(255,255,255,0.4); 
  }
  .loading-text { 
    font-size: 32rpx; 
    color: #2d8cf0; 
  }
  
  /* 页面背景 */
  page { 
    background: #f5fafe; 
  }
  .glass-bg { 
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%); 
    min-height: 100vh; 
    padding: 20rpx; 
    box-sizing: border-box;
  }
  
  /* 毛玻璃卡片 */
  .glass-card { 
    background: rgba(255,255,255,0.55); 
    -webkit-backdrop-filter: blur(25rpx);
    backdrop-filter: blur(25rpx); 
    border-radius: 24rpx; 
    margin-bottom: 24rpx; 
    padding: 30rpx; 
    box-shadow: 0 8rpx 30rpx rgba(0,80,180,0.08); 
    box-sizing: border-box;
  }
  
  /* 订单状态 */
  .status-card { 
    text-align: center; 
  }
  .status-title { 
    font-size: 40rpx; 
    font-weight: bold;
    color: #2d8cf0; 
    margin-bottom: 10rpx; 
  }
  .status-desc { 
    font-size: 26rpx; 
    color: #666; 
  }
  
  /* 商品信息 */
  .goods-card { 
    display: flex; 
    align-items: center; 
  }
  /* ✅ 完全和你参考页一样的图片样式 */
  .goods-img { 
    width: 140rpx; 
    height: 140rpx; 
    border-radius: 20rpx; 
    margin-right: 24rpx; 
    flex-shrink: 0;
  }
  .goods-info { 
    flex: 1; 
  }
  .goods-name { 
    font-size: 32rpx; 
    color: #333; 
    margin-bottom: 12rpx; 
    line-height: 1.4; 
  }
  .goods-price { 
    font-size: 34rpx; 
    color: #fa5555; 
    font-weight: bold; 
  }
  
  /* 订单信息 */
  .info-card .row { 
    display: flex; 
    justify-content: space-between; 
    align-items: center;
    padding: 22rpx 0; 
    border-bottom: 1rpx solid rgba(0,0,0,0.05); 
    font-size: 28rpx; 
    width: 100%;
    box-sizing: border-box;
  }
  .info-card .row:last-child { 
    border-bottom: none; 
  }
  .row text:first-child { 
    color: #666; 
    flex-shrink: 0;
    margin-right: 20rpx;
  }
  .row text:last-child { 
    color: #333; 
    font-weight: 500; 
    text-align: right;
    flex: 1;
    word-wrap: break-word;
    word-break: break-all;
    white-space: normal;
  }
  
  .text-over {
    word-wrap: break-word !important;
    word-break: break-all !important;
    white-space: normal !important;
    text-align: right !important;
  }
  
  /* 商品描述 */
  .desc-card .title { 
    font-size: 30rpx; 
    color: #333; 
    margin-bottom: 20rpx; 
    font-weight: 500;
  }
  .desc-card .content { 
    font-size: 28rpx; 
    color: #666; 
    line-height: 1.7; 
  }
  
  .placeholder { 
    height: 140rpx; 
  }
  
  /* 底部按钮 */
  .footer-bar {
    position: fixed; 
    bottom: 0; 
    left: 0; 
    width: 100%;
    background: rgba(255,255,255,0.8); 
    -webkit-backdrop-filter: blur(30rpx);
    backdrop-filter: blur(30rpx);
    border-top: 1rpx solid #eee; 
    padding: 20rpx 30rpx; 
    box-sizing: border-box;
  }
  .btn-box {
    width: 100%;
  }
  .btn-row {
    display: flex;
    gap: 20rpx;
    width: 100%;
  }
  .btn { 
    flex: 1; 
    height: 80rpx; 
    border-radius: 40rpx; 
    font-size: 28rpx; 
    color: #fff; 
    border: none; 
  }
  .btn.blue { 
    background: #2d8cf0; 
  }
  .btn.red { 
    background: #fa5555; 
  }
  .btn.green { 
    background: #00c48c; 
  }
  .btn.orange { 
    background: #ff9500; 
  }
  .btn.gray { 
    background: #999; 
  }