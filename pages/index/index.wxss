/* ========== 全局玻璃拟态升级 ========== */
.glass-bg {
  background: linear-gradient(165deg, #eef6ff 0%, #f3f9ff 40%, #e8f4fd 100%);
  min-height: 100vh;
  position: relative;
  overflow-x: hidden;
}

.glass-float {
  background: rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(28px);
  -webkit-backdrop-filter: blur(28px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8px 30px rgba(74, 123, 247, 0.1);
}

.glass-card {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(22px);
  -webkit-backdrop-filter: blur(22px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8px 24px rgba(74, 123, 247, 0.08);
  border-radius: 24rpx;
  transition: all 0.25s ease;
}

.glass-input {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4px 16px rgba(74, 123, 247, 0.06);
}

.glass-btn {
  background: rgba(102, 175, 239, 0.25);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  color: #2d8cf0;
  transition: all 0.2s;
}

.glass-btn:active {
  background: rgba(102, 175, 239, 0.4);
  transform: scale(0.96);
}

/* ========== 容器与搜索栏 ========== */
.container {
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.header-search {
  position: sticky;
  top: 0;
  z-index: 999;
  padding: 20rpx 16rpx;
  border-radius: 0 0 30rpx 30rpx;
}

.search-wrapper {
  display: flex;
  align-items: center;
  border-radius: 60rpx;
  padding: 0 16rpx;
  height: 88rpx;
}

.search-icon-wrap {
  margin-right: 10rpx;
  display: flex;
  align-items: center;
}

.icon-search {
  font-size: 34rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0,0,0,0.05));
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1e2b3c;
  height: 100%;
}

.search-btn {
  padding: 0 30rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  margin-left: 16rpx;
  font-weight: 500;
}

.btn-text {
  letter-spacing: 1rpx;
}

/* ========== 轮播图美化 ========== */
.banner-swiper {
  width: 100%;
  height: 320rpx;
  border-radius: 28rpx;
  overflow: hidden;
  margin: 20rpx 0 30rpx;
  box-shadow: 0 12px 30px rgba(74, 123, 247, 0.12);
}

.banner-item {
  width: 100%;
  height: 100%;
}

.banner-content {
  width: 100%;
  height: 100%;
  position: relative;
}

.banner-img {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 28rpx;
}

.banner-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.15), transparent);
  border-radius: 0 0 28rpx 28rpx;
}

/* 指示器增强 */
swiper .wx-swiper-dot {
  width: 12rpx;
  height: 12rpx;
  background: rgba(255,255,255,0.6);
  border-radius: 6rpx;
  transition: all 0.3s;
}

swiper .wx-swiper-dot-active {
  width: 24rpx;
  background: #fff;
}

/* ========== 分类图标（渐变背景 + 悬浮效果） ========== */
.category-list {
  display: flex;
  justify-content: space-between;
  margin-bottom: 35rpx;
  padding: 0 10rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 20%;
}

.category-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.6);
  box-shadow: 0 6px 18px rgba(74, 123, 247, 0.08);
  transition: transform 0.2s;
}

.category-icon:active {
  transform: scale(0.92);
}

.category-icon image {
  width: 48rpx;
  height: 48rpx;
}

/* 每个分类独特的渐变色 */
.cat-books {
  background: linear-gradient(135deg, #d6e8ff, #b8d4fe);
}
.cat-digital {
  background: linear-gradient(135deg, #ffe6cc, #ffcf9a);
}
.cat-clothes {
  background: linear-gradient(135deg, #daf4ff, #b1e6fc);
}
.cat-electric {
  background: linear-gradient(135deg, #fff5cc, #ffe38c);
}
.cat-others {
  background: linear-gradient(135deg, #ebd9ff, #d3b8f0);
}

.category-name {
  font-size: 24rpx;
  color: #445671;
  font-weight: 500;
}

/* ========== 商品标题 ========== */
.goods-title {
  display: flex;
  align-items: center;
  padding: 24rpx 10rpx 16rpx;
}

.title-deco {
  width: 6rpx;
  height: 34rpx;
  background: linear-gradient(to bottom, #4a7bf7, #8cb3ff);
  border-radius: 10rpx;
  margin-right: 14rpx;
}

.title-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e2b3c;
  letter-spacing: 1rpx;
}

/* ========== 加载动画 ========== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.dot-wave {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: #4a7bf7;
  border-radius: 50%;
  opacity: 0.3;
  animation: wave 1.4s infinite ease-in-out both;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}
.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes wave {
  0%, 80%, 100% {
    transform: translateY(0);
    opacity: 0.3;
  }
  40% {
    transform: translateY(-20rpx);
    opacity: 1;
  }
}

.loading-text {
  color: #2d4b7a;
  font-size: 28rpx;
}

/* ========== 商品列表（继承原有宽度逻辑，优化视觉效果） ========== */
.goods-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 0 10rpx;
  margin-bottom: 40rpx;
}

.goods-item {
  width: calc(50% - 10rpx);
  min-width: 320rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.7);
  box-sizing: border-box;
  flex: 1;
  transition: transform 0.2s, box-shadow 0.2s;
}

.goods-item:active {
  transform: scale(0.97);
  box-shadow: 0 12px 28px rgba(74, 123, 247, 0.15);
}

.img-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.goods-img {
  width: 100%;
  height: 300rpx;
  border-radius: 20rpx;
  display: block;
  background: #f0f4ff;
}

.img-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: rgba(0,0,0,0.55);
  backdrop-filter: blur(8px);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.goods-name {
  font-size: 26rpx;
  color: #1f2e45;
  line-height: 1.4;
  height: 70rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.goods-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff3b3b;
  margin-bottom: 18rpx;
  letter-spacing: 0.5rpx;
}

.price-symbol {
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 2rpx;
}

.goods-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22rpx;
  color: #718096;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 2rpx solid rgba(255,255,255,0.9);
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.username {
  max-width: 110rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  color: #4a5b6e;
}

.time {
  color: #a0b0c0;
  font-size: 20rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: rgba(255,255,255,0.4);
  border-radius: 30rpx;
  margin: 20rpx 10rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
  filter: grayscale(0.3);
}

.empty-desc {
  color: #8795a8;
  font-size: 28rpx;
}