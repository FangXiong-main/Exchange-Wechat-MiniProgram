/* ====================== 液态玻璃 + 浅蓝色背景 ====================== */
.glass-bg {
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    min-height: 100vh;
  }
  
  .glass-float {
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    box-shadow: 0 8px 32px rgba(100, 120, 200, 0.12);
  }
  
  .glass-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 8px 32px rgba(100, 120, 200, 0.1);
    border-radius: 20rpx;
  }
  
  .glass-input {
    background: rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.4);
  }
  
  .glass-btn {
    background: rgba(102, 175, 239, 0.3);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #2d8cf0 !important;
  }
  
  .glass-filter {
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
    border: 1px solid rgba(255, 255, 255, 0.25);
  }
  
  .glass-picker {
    background: transparent !important;
    border: none !important;
  }
  
  .glass-icon {
    background: rgba(255, 255, 255, 0.6) !important;
    backdrop-filter: blur(12px) !important;
    -webkit-backdrop-filter: blur(12px) !important;
    border: 1px solid rgba(255, 255, 255, 0.35) !important;
  }
  
  /* ====================== 原有布局样式（不动） ====================== */
  .container {
    padding: 20rpx;
    box-sizing: border-box;
  }
  
  .header-search {
    position: sticky;
    top: 0;
    z-index: 999;
    padding: 20rpx;
    border-radius: 0 0 20rpx 20rpx;
  }
  
  .search-wrapper {
    display: flex;
    align-items: center;
    border-radius: 50rpx;
    padding: 0 20rpx;
    height: 88rpx;
  }
  
  .search-icon {
    margin-right: 16rpx;
  }
  
  .search-input {
    flex: 1;
    font-size: 28rpx;
    color: #333;
  }
  
  .search-btn {
    padding: 0 30rpx;
    height: 64rpx;
    line-height: 64rpx;
    border-radius: 32rpx;
    font-size: 26rpx;
    margin-left: 16rpx;
  }
  
  .banner-swiper {
    width: 100%;
    height: 320rpx;
    border-radius: 24rpx;
    overflow: hidden;
    margin-bottom: 30rpx;
  }
  
  .banner-item {
    width: 100%;
    height: 100%;
  }
  
  .banner-content {
    width: 100%;
    height: 100%;
    padding: 0;
    position: relative;
  }
  
  .banner-img {
    width: 100%;
    height: 100%;
  }
  
  .category-list {
    display: flex;
    justify-content: space-between;
    margin-bottom: 40rpx;
  }
  
  .category-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 20%;
  }
  
  .category-icon {
    width: 88rpx;
    height: 88rpx;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16rpx;
  }
  
  .category-icon image {
    width: 48rpx;
    height: 48rpx;
  }
  
  .category-name {
    font-size: 24rpx;
    color: #555;
  }
  
  .bg-blue { background: #dbebff; }
  .bg-orange { background: #fff0db; }
  .bg-lightblue { background: #e0f7ff; }
  .bg-yellow { background: #fff9e0; }
  .bg-purple { background: #f0e1ff; }

  .bg-purple { background: #f0e1ff; }

/* ====================== 商品列表 · 自适应布局 ====================== */
.goods-list {
    display: flex;
    flex-wrap: wrap;
    gap: 20rpx;        /* 间距自动适配 */
    padding: 0 10rpx;
  }
  
  /* 关键：自适应！
     屏幕 ≥ 400rpx → 一行2个
     屏幕  < 400rpx → 一行1个铺满
  */
  .goods-item {
    width: calc(50% - 10rpx);
    min-width: 320rpx;
    padding: 24rpx;
    border-radius: 20rpx;
    background: rgba(255,255,255,0.8);
    box-sizing: border-box;
    flex: 1;
  }
  
  .goods-img {
    width: 100%;
    height: 240rpx;
    border-radius: 16rpx;
    object-fit: cover;
    margin-bottom: 16rpx;
  }
  
  .goods-name {
    font-size: 26rpx;
    color: #222;
    line-height: 1.4;
    height: 72rpx;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    margin-bottom: 12rpx;
  }
  
  .goods-price {
    font-size: 34rpx;
    font-weight: bold;
    color: #ff3333;
    margin-bottom: 20rpx;
  }
  
  .goods-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 22rpx;
    color: #777;
  }
  
  .user-info {
    display: flex;
    align-items: center;
    gap: 8rpx;
  }
  
  .avatar {
    width: 36rpx;
    height: 36rpx;
    border-radius: 50%;
  }
  
  .username {
    max-width: 100rpx;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  
  .time {
    color: #bbb;
    font-size: 20rpx;
  }