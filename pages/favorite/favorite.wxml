<view wx:if="{{loading}}" class="loading-overlay">
  <view class="loading-glass">
    <view class="loading-text">加载中...</view>
  </view>
</view>

<view class="container glass-bg">

  <view class="list-box" wx:if="{{favoriteList.length > 0}}">
    <view class="list-item glass-card" wx:for="{{favoriteList}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
      <image class="item-img" src="{{item.mainImg}}" mode="aspectFill"></image>
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-price">¥{{item.price}}</text>
    
        <view class="status-wrap">
          <view class="dot {{item.saleStatus === 1 ? 'green' : 'red'}}"></view>
          <text class="status-text">{{item.saleStatus === 1 ? '在售' : '已下架'}}</text>
        </view>
        <text class="date">发布于 {{item.createTime}}</text>
      </view>
    </view>
  </view>

  <view class="empty-box" wx:else>
    <view class="empty-card glass-card">
      <text class="empty-text">暂无收藏商品</text>
    </view>
  </view>

  <view class="load-tip" wx:if="{{!hasMore && favoriteList.length > 0}}">没有更多了</view>
</view>