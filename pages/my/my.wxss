/* 全屏加载 */
.loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
}
.loading-glass {
    padding: 50rpx 80rpx;
    border-radius: 20rpx;
    background: rgba(255,255,255,0.25);
    border: 1rpx solid rgba(255,255,255,0.3);
}
.loading-text {
    font-size: 32rpx;
    color: #2d8cf0;
    font-weight: bold;
}

/* 统一玻璃样式 */
.glass-bg {
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    min-height: 100vh;
}
.glass-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 8px 32px rgba(100, 120, 200, 0.1);
    border-radius: 20rpx;
}
.glass-btn {
    background: rgba(102, 175, 239, 0.3);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #2d8cf0 !important;
}

/* 布局 */
.container {
    padding: 30rpx;
    box-sizing: border-box;
}
.user-card {
    display: flex;
    align-items: center;
    padding: 30rpx;
    margin-bottom: 30rpx;
}
.avatar {
    width: 120rpx;
    height: 120rpx;
    border-radius: 50%;
    margin-right: 24rpx;
}
.user-info {
    flex: 1;
}
.nickname {
    font-size: 32rpx;
    font-weight: bold;
    line-height: 1.2;
}
.edit-btn {
    padding: 0 24rpx;
    height: 56rpx;
    line-height: 56rpx;
    border-radius: 28rpx;
    font-size: 24rpx;
    white-space: nowrap;
}

/* 审核中提示 */
.audit-tip {
    background: rgba(255, 193, 7, 0.1);
    border: 1rpx solid rgba(255, 193, 7, 0.2);
    color: #e6a700;
    padding: 20rpx;
    border-radius: 16rpx;
    text-align: center;
    margin-bottom: 30rpx;
    font-size: 26rpx;
}

.menu-box {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
}
/* 去掉align-items:center，内容靠左 */
.menu-item {
    display: flex;
    justify-content: space-between;
    padding: 30rpx;
    font-size: 28rpx;
}
.menu-left-wrap{
  display: flex;
  align-items: center;
}
.arrow {
    color: #999;
}
/* 红色待处理订单标签 */
.order-tip{
  color: #f53f3f;
  font-size:24rpx;
  margin-left:20rpx;
  font-weight:bold;
}
.logout-box {
    margin-top: 60rpx;
}
.logout-btn {
    text-align: center;
    padding: 24rpx;
    border-radius: 20rpx;
    font-size: 28rpx;
}
.school-text {
    display: block;
    font-size: 24rpx;
    color: #666;
    margin-top: 8rpx;
    font-weight: normal;
}

/* 菜单图标样式 */
.menu-icon {
    font-size: 32rpx;
    margin-right: 20rpx;
    line-height: 1;
}