/* 加载 */
.loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(12rpx);
  }
  
  .loading-glass {
    padding: 50rpx 80rpx;
    border-radius: 24rpx;
    background: rgba(255,255,255,0.3);
    border: 1rpx solid rgba(255,255,255,0.4);
  }
  
  .loading-text {
    font-size: 32rpx;
    color: #2d8cf0;
  }
  
  page {
    background: #f5fafe;
  }
  
  .glass-bg {
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
    min-height: 100vh;
    padding: 20rpx;
  }
  
  .glass-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(25rpx);
    border-radius: 24rpx;
    padding: 30rpx;
    box-shadow: 0 8rpx 30rpx rgba(0,80,180,0.08);
  }
  
  /* 订单列表 */
  .list-item {
    display: flex;
    margin-bottom: 24rpx;
  }
  
  .item-img {
    width: 120rpx;
    height: 120rpx;
    border-radius: 16rpx;
    margin-right: 24rpx;
  }
  
  .item-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8rpx;
  }
  
  .item-name {
    font-size: 30rpx;
    color: #333;
    font-weight: 500;
  }
  
  .item-price {
    font-size: 32rpx;
    color: #fa5555;
    font-weight: bold;
  }
  
  /* 状态布局 */
  .status-row {
    display: flex;
    align-items: center;
    gap: 20rpx;
  }
  
  .status-text-view {
    display: flex;
    align-items: center;
    gap: 8rpx;
  }
  
  .dot {
    width: 12rpx;
    height: 12rpx;
    border-radius: 50%;
    flex-shrink: 0;
  }
  
  .dot.gray { background: #999; }
  .dot.blue { background: #2d8cf0; }
  .dot.orange { background: #ff9500; }
  .dot.green { background: #00c48c; }
  .dot.red { background: #ff4d4f; }
  
  .status-txt {
    font-size: 24rpx;
    color: #666;
    white-space: nowrap;
  }
  
  .tag {
    font-size: 22rpx;
    padding: 6rpx 12rpx;
    border-radius: 8rpx;
    flex-shrink: 0;
    white-space: nowrap;
  }
  
  .tag.buy {
    background: #e6f7ff;
    color: #2d8cf0;
  }
  
  .tag.sell {
    background: #f0fff4;
    color: #00c48c;
  }
  
  .date {
    font-size: 24rpx;
    color: #999;
  }
  
  /* 空状态 */
  .empty-box {
    display: flex;
    justify-content: center;
    margin-top: 100rpx;
  }
  
  .empty-text {
    font-size: 30rpx;
    color: #999;
  }
  
  .load-tip {
    text-align: center;
    padding: 20rpx;
    color: #999;
    font-size: 26rpx;
  }