
/* ========== 全局变量与基础 ========== */
page {
  --primary: #4a7bf7;
  --primary-light: #a0c4ff;
  --bg-start: #e9f0ff;
  --bg-end: #f4f8ff;
  --card-bg: rgba(255, 255, 255, 0.6);
  --shadow-sm: 0 8rpx 24rpx rgba(74, 123, 247, 0.08);
  --shadow-md: 0 16rpx 32rpx rgba(74, 123, 247, 0.12);
}

.glass-bg {
  background: linear-gradient(160deg, var(--bg-start) 0%, #f0f4ff 40%, var(--bg-end) 100%);
  min-height: 100vh;
}

.glass-card {
  background: var(--card-bg);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.glass-card:active {
  transform: scale(0.99);
  box-shadow: var(--shadow-md);
}

/* ========== 标题区 ========== */
.search-top-title {
  padding: 30rpx 10rpx 15rpx;
  display: flex;
  align-items: center;
}

.title-decor {
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(to bottom, var(--primary), var(--primary-light));
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a2c4b;
  letter-spacing: 1rpx;
}

/* ========== 列表 ========== */
.container {
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.circle-list {
  margin-top: 10rpx;
  padding-bottom: 120rpx;
}

.circle-item {
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 24rpx;
}

/* 用户信息 */
.circle-user {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 12rpx rgba(74, 123, 247, 0.15);
}

.user-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e2f47;
  line-height: 1.2;
}

.time {
  font-size: 22rpx;
  color: #8c9bb5;
  margin-top: 4rpx;
}

/* 内容 */
.circle-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #2e3b52;
  margin: 12rpx 0 16rpx;
  word-break: break-all;
}

/* 图片 */
.circle-img {
  width: 100%;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* 底部操作栏 */
.circle-action {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #66748b;
  padding-top: 10rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.5);
}

.action-left {
  display: flex;
  gap: 36rpx;
}

/* 类型标签 */
.type-tag {
  background: linear-gradient(135deg, #eef5ff, #dae9ff);
  color: var(--primary);
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(74, 123, 247, 0.15);
  letter-spacing: 1rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 140rpx 0;
  color: #8b9cb5;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 30rpx;
  margin-top: 30rpx;
}

.empty-icon {
  font-size: 56rpx;
  margin-bottom: 20rpx;
}

/* ========== 加载遮罩（升级为光点扩散动画） ========== */
.liquid-loading-mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
}

.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.loader {
  position: relative;
  width: 80rpx;
  height: 80rpx;
}

.loader-dot {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: var(--primary);
  animation: wave 1.4s ease-in-out infinite both;
}

.dot1 {
  top: 0;
  left: calc(50% - 10rpx);
  animation-delay: -0.32s;
}

.dot2 {
  top: calc(50% - 10rpx);
  left: calc(100% - 20rpx);
  animation-delay: -0.16s;
}

.dot3 {
  top: calc(50% - 10rpx);
  left: 0;
  animation-delay: 0s;
}

@keyframes wave {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
    box-shadow: 0 0 16rpx var(--primary-light);
  }
  40% {
    transform: scale(1.2);
    opacity: 1;
    box-shadow: 0 0 28rpx var(--primary);
  }
}

.loading-text {
  color: #2a3b5c;
  font-size: 28rpx;
  font-weight: 500;
  background: linear-gradient(to right, var(--primary-light), var(--primary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}