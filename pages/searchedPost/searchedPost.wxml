
<view>
  <view class="container glass-bg">

    <!-- 标题区 -->
    <view class="search-top-title">
      <view class="title-decor"></view>
      <text class="title">{{pageTitle}}</text>
    </view>

    <!-- 帖子列表 -->
    <view class="circle-list">
      <view class="circle-item glass-card" wx:for="{{postList}}" wx:key="id" bindtap="goDetail" data-item="{{item}}">
        <view class="circle-user">
          <image class="avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
          <view class="user-info">
            <text class="nickname">{{item.username}}</text>
            <text class="time">{{item.createTime}}</text>
          </view>
        </view>

        <view class="circle-content">{{item.content}}</view>

        <image wx:if="{{item.img}}" class="circle-img" src="{{item.img}}" mode="aspectFill"></image>

        <!-- 底部栏 -->
        <view class="circle-action">
          <view class="action-left">
            <text>👀 浏览 {{item.viewCount}} 次</text>
            <text>💬 评论 {{item.commentCount}} 条</text>
          </view>
          <view class="type-tag" wx:if="{{item.typeName}}">
            {{item.typeName}}
          </view>
        </view>
      </view>

      <view wx:if="{{postList.length === 0 && !loading}}" class="empty-state">
        <text class="empty-icon">🔍</text>
        <text>{{emptyTip}}</text>
      </view>
    </view>
  </view>

  <!-- 液态玻璃加载遮罩 -->
  <view wx:if="{{loading}}" class="liquid-loading-mask">
    <view class="loading-box">
      <view class="loader">
        <view class="loader-dot dot1"></view>
        <view class="loader-dot dot2"></view>
        <view class="loader-dot dot3"></view>
      </view>
      <text class="loading-text">正在搜索...</text>
    </view>
  </view>
</view>