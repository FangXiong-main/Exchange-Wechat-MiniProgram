/* 加载动画 */
.loading-overlay {
    position: fixed; 
    top: 0; 
    left: 0; 
    width: 100%; 
    height: 100%;
    z-index: 9999; 
    display: flex; 
    align-items: center; 
    justify-content: center;
    background: rgba(255,255,255,0.15); 
    backdrop-filter: blur(12rpx);
  }
  .loading-glass { 
    padding: 50rpx 80rpx; 
    border-radius: 24rpx; 
    background: rgba(255,255,255,0.3); 
    border: 1rpx solid rgba(255,255,255,0.4); 
  }
  .loading-text { 
    font-size: 32rpx; 
    color: #2d8cf0; 
  }
  
  /* 页面背景 */
  page { 
    background: #f5fafe; 
  }
  .glass-bg { 
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%); 
    min-height: 100vh; 
    padding: 20rpx; 
    box-sizing: border-box;
  }
  .glass-card { 
    background: rgba(255,255,255,0.55); 
    backdrop-filter: blur(25rpx); 
    border-radius: 24rpx; 
    margin-bottom: 24rpx; 
    padding: 30rpx; 
    box-shadow: 0 8rpx 30rpx rgba(0,80,180,0.08); 
    box-sizing: border-box;
  }
  
  /* 顶部标题卡片 */
  .status-card { 
    text-align: center; 
  }
  .status-title { 
    font-size: 40rpx; 
    font-weight: bold;
    color: #2d8cf0; 
    margin-bottom: 10rpx; 
  }
  .status-desc { 
    font-size: 26rpx; 
    color: #666; 
  }
  
  /* 表单通用 */
  .form-label {
    font-size: 28rpx;
    color: #333;
    margin-bottom: 20rpx;
    font-weight: 500;
  }
  .form-input {
    width: 100%;
    height: 80rpx;
    padding: 0 20rpx;
    background: #fff;
    border-radius: 12rpx;
    font-size: 28rpx;
    box-sizing: border-box;
    border: 1rpx solid #eee;
  }
  .form-textarea {
    width: 100%;
    min-height: 180rpx;
    padding: 20rpx;
    background: #fff;
    border-radius: 12rpx;
    font-size: 28rpx;
    line-height: 1.6;
    box-sizing: border-box;
    border: 1rpx solid #eee;
  }

  /* 下拉选择框样式 */
  .picker-input {
    width: 100%;
    height: 80rpx;
    line-height: 80rpx;
    padding: 0 20rpx;
    background: #fff;
    border-radius: 12rpx;
    font-size: 28rpx;
    color: #333;
    border: 1rpx solid #eee;
    box-sizing: border-box;
  }
  
  /* 图片区域 */
  .img-section {
    display: flex;
    align-items: center;
    gap: 24rpx;
  }
  .show-img {
    width: 140rpx;
    height: 140rpx;
    border-radius: 20rpx;
    object-fit: cover;
    flex-shrink: 0;
  }
  .img-section .btn {
    flex: 1;
    margin: 0;
  }
  
  /* 底部占位 */
  .placeholder { 
    height: 140rpx; 
  }
  
  /* 底部按钮栏 */
  .footer-bar {
    position: fixed; 
    bottom: 0; 
    left: 0; 
    width: 100%;
    background: rgba(255,255,255,0.8); 
    backdrop-filter: blur(30rpx);
    border-top: 1rpx solid #eee; 
    padding: 20rpx 30rpx; 
    box-sizing: border-box;
  }
  .btn-row {
    display: flex;
    gap: 20rpx;
    width: 100%;
  }
  .btn { 
    flex: 1; 
    height: 80rpx; 
    border-radius: 40rpx; 
    font-size: 28rpx; 
    color: #fff; 
    border: none; 
    margin: 0;
  }
  .btn.blue { 
    background: #2d8cf0; 
  }
  .btn.gray { 
    background: #999; 
  }