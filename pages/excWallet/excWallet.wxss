page {
    background: #f5fafe;
  }
  .glass-bg {
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
    min-height: 100vh;
    padding: 20rpx;
  }
  .glass-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(25rpx);
    border-radius: 24rpx;
    padding: 30rpx;
    box-shadow: 0 8rpx 30rpx rgba(0,80,180,0.08);
  }
  
  /* 标题 */
  .wallet-title {
    font-size: 40rpx;
    font-weight: bold;
    color: #2d8cf0;
    text-align: center;
    margin: 20rpx 0 40rpx;
  }
  
  /* 余额卡片 */
  .balance-card {
    text-align: center;
    margin-bottom: 40rpx;
  }
  .balance-label {
    font-size: 28rpx;
    color: #666;
    margin-bottom: 16rpx;
  }
  .balance-num {
    font-size: 50rpx;
    font-weight: bold;
    color: #2d8cf0;
  }
  
  /* 明细标题 */
  .detail-title {
    font-size: 32rpx;
    font-weight: 500;
    color: #333;
    margin-bottom: 20rpx;
  }
  
  .list-box {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
  }
  .detail-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .detail-left {
    display: flex;
    flex-direction: column;
    gap: 8rpx;
  }
  .type-text {
    font-size: 30rpx;
    color: #333;
    font-weight: 500;
  }
  .time-text {
    font-size: 24rpx;
    color: #999;
  }
  .price-text {
    font-size: 30rpx;
    font-weight: bold;
  }
  .price-text.blue {
    color: #2d8cf0;
  }
  .price-text.gray {
    color: #888;
  }
  
  /* 空态 */
  .empty-box {
    display: flex;
    justify-content: center;
    margin-top: 60rpx;
  }
  .empty-text {
    font-size: 30rpx;
    color: #999;
  }
  
  /* 明细加载/底线提示 */
  .loading-row, .load-tip {
    text-align: center;
    padding: 24rpx;
    font-size: 26rpx;
    color: #999;
  }