/* 全局液态玻璃背景 */
.container {
    padding: 30rpx;
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
    min-height: 100vh;
    box-sizing: border-box;
  }
  
  /* 玻璃卡片通用 */
  .glass-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(25px);
    border-radius: 20rpx;
    margin-bottom: 30rpx;
    overflow: hidden;
  }
  
  /* 商品卡片 */
  .goods-card {
    padding: 30rpx;
  }
  
  .title {
    font-size: 32rpx;
    color: #333;
    margin-bottom: 10rpx;
  }
  
  .price {
    font-size: 40rpx;
    color: #fa5555;
    font-weight: bold;
    margin-bottom: 10rpx;
  }
  
  .seller {
    font-size: 26rpx;
    color: #666;
  }
  
  /* 支付方式 */
  .pay-section {
    padding: 30rpx;
  }
  
  .section-title {
    font-size: 30rpx;
    font-weight: 500;
    color: #333;
    margin-bottom: 20rpx;
  }
  
  .pay-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20rpx 0;
    border-radius: 12rpx;
    transition: all 0.2s ease;
  }
  
  .pay-item.active {
    background: rgba(45, 140, 240, 0.1);
    padding: 20rpx;
    margin: 0 -20rpx;
  }
  
  .radio-wrap {
    display: flex;
    align-items: center;
  }
  
  .radio {
    width: 32rpx;
    height: 32rpx;
    border-radius: 50%;
    border: 2rpx solid #ccc;
    margin-right: 16rpx;
    position: relative;
    transition: all 0.2s ease;
  }
  
  .radio.checked {
    border-color: #4080ff;
  }
  
  .radio.checked::after {
    content: "";
    position: absolute;
    width: 16rpx;
    height: 16rpx;
    background: #4080ff;
    border-radius: 50%;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }
  
  .pay-name {
    font-size: 28rpx;
    color: #333;
  }
  
  .balance {
    font-size: 26rpx;
    color: #666;
  }
  
  /* 按钮组 */
  .btn-group {
    display: flex;
    gap: 20rpx;
    margin-top: 20rpx;
  }
  
  .btn {
    flex: 1;
    height: 80rpx;
    border-radius: 40rpx;
    text-align: center;
    line-height: 80rpx;
    font-size: 30rpx;
    font-weight: 500;
  }
  
  /* 取消按钮 */
  .cancel {
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(20px);
    color: #666;
    border: 1rpx solid rgba(255, 255, 255, 0.5);
  }
  
  /* 确认购买按钮 */
  .confirm {
    background: linear-gradient(90deg, #4080ff, #60a0ff);
    color: #fff;
    box-shadow: 0 8rpx 20rpx rgba(64, 128, 255, 0.2);
  }
  
  .confirm.disabled {
    background: #ccc !important;
    color: #fff !important;
    pointer-events: none;
    box-shadow: none;
  }