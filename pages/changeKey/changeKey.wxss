/* 全屏加载 */
.loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  
  .loading-glass {
    padding: 50rpx 80rpx;
    border-radius: 20rpx;
    background: rgba(255,255,255,0.25);
    border: 1px solid rgba(255,255,255,0.3);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
  }
  
  .loading-text {
    font-size: 32rpx;
    color: #2d8cf0;
    font-weight: bold;
  }
  
  /* 液态玻璃 */
  .glass-bg {
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    min-height: 100vh;
  }
  
  .glass-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 8px 32px rgba(100, 120, 200, 0.1);
    border-radius: 20rpx;
  }
  
  .glass-btn {
    background: rgba(102, 175, 239, 0.3);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #2d8cf0 !important;
  }
  
  .code-btn[disabled],
  .login-btn[disabled] {
    opacity: 0.5;
  }
  
  /* 布局 */
  .container {
    padding: 20rpx;
    box-sizing: border-box;
  }
  
  .title-box {
    margin: 80rpx 0 50rpx;
    text-align: center;
  }
  
  .main-title {
    display: block;
    font-size: 50rpx;
    font-weight: bold;
    color: #2d8cf0;
    margin-bottom: 20rpx;
  }
  
  .sub-title {
    font-size: 28rpx;
    color: #666;
  }
  
  .form-animate {
    animation: formFade 0.4s ease;
  }
  
  @keyframes formFade {
    0% {
      opacity: 0;
      transform: translateY(10rpx);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .form-box {
    padding: 30rpx;
    margin-bottom: 40rpx;
  }
  
  .input-item {
    padding: 24rpx 20rpx;
    border-bottom: 1rpx solid rgba(100, 120, 200, 0.1);
  }
  
  .input-item:last-child {
    border-bottom: none;
  }
  
  .input-item input {
    font-size: 28rpx;
    color: #333;
  }
  
  .code-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  
  .code-item input {
    flex: 1;
  }
  
  .code-btn {
    padding: 16rpx 24rpx;
    border-radius: 16rpx;
    font-size: 24rpx;
  }
  
  .login-btn {
    text-align: center;
    padding: 28rpx 0;
    font-size: 32rpx;
    font-weight: bold;
    border-radius: 20rpx;
    margin-top: 20rpx;
  }