<!-- 全屏加载 -->
<view wx:if="{{loading}}" class="loading-overlay">
  <view class="loading-glass">
    <view class="loading-text">{{loadingText}}</view>
  </view>
</view>

<view class="container glass-bg">
  <!-- 标题 -->
  <view class="title-box">
    <text class="main-title">修改密码</text>
    <text class="sub-title">请通过邮箱验证重置密码</text>
  </view>

  <!-- 表单 -->
  <view class="form-box glass-card form-animate">
    <!-- 邮箱 -->
    <view class="input-item">
      <input placeholder="请输入邮箱" bindinput="inputEmail" value="{{email}}" />
    </view>

    <!-- 验证码 -->
    <view class="input-item code-item">
    <input placeholder="请输入验证码" bindinput="inputCode" value="{{code}}" />
    <view 
        class="code-btn glass-btn" 
        bindtap="sendCode"
        disabled="{{!canSend || sending}}"
    >
        {{codeText}}
    </view>
    </view>

    <!-- 新密码 -->
    <view class="input-item">
      <input placeholder="请输入新密码（6位以上+字母+数字+符号）" password bindinput="inputNewPwd" value="{{newPwd}}" />
    </view>

    <!-- 确认新密码 -->
    <view class="input-item">
      <input placeholder="请再次输入新密码" password bindinput="inputConfirmPwd" value="{{confirmPwd}}" />
    </view>
  </view>

  <!-- 确认修改按钮 -->
  <view class="login-btn glass-btn" bindtap="doChangePwd" disabled="{{loading}}">
    <text>确认修改密码</text>
  </view>
</view>