<!-- 全屏加载 -->
<view wx:if="{{loading}}" class="loading-overlay">
  <view class="loading-glass">
    <view class="loading-text">{{loadingText}}</view>
  </view>
</view>

<view class="container glass-bg">
  <!-- 头部标题 -->
  <view class="header glass-card">
    <text class="title red-title">注销Exchange!账号</text>
    <text class="sub-desc">此操作不可逆，请务必谨慎</text>
  </view>

  <!-- 重要提醒 -->
  <view class="content glass-card warning-section">
    <text class="p bold">⚠️ 重要提醒：</text>
    <text class="p red-warning">1. 你的所有账号数据、交易记录、发布信息将被永久删除。</text>
    <text class="p red-warning">2. 请确认你的 EXC-Wallet 钱包内已无任何余额，否则资产将永久丢失。</text>
    <text class="p red-warning">3. 账号一旦注销，无法恢复，所有后果由您自行承担。</text>
  </view>

  <!-- 免责说明 -->
  <view class="content glass-card">
    <text class="p small-title">免责声明：</text>
    <text class="p">1. 账号注销为用户主动行为，平台不承担因误操作造成的任何损失。</text>
    <text class="p">2. 注销前请自行完成资产转移、数据备份，因未清空钱包余额造成的损失自行负责。</text>
    <text class="p">3. 注销后所有与账号相关的功能将立即失效，无法找回、无法恢复、无法申诉。</text>
    <text class="p">4. 凡点击确认注销，即代表您已充分知晓风险并自愿承担全部责任。</text>
  </view>

  <!-- 验证表单 -->
  <view class="form-box glass-card">
    <view class="input-item">
      <input placeholder="请输入当前账号邮箱" bindinput="inputEmail" value="{{email}}" />
    </view>

    <view class="input-item code-item">
      <input placeholder="请输入验证码" bindinput="inputCode" value="{{code}}" />
      <view 
        class="code-btn glass-btn" 
        bindtap="sendCode"
        disabled="{{!canSend || sending}}"
      >
        {{codeText}}
      </view>
    </view>
  </view>

  <!-- 注销按钮（红色） -->
  <view class="delete-btn" bindtap="doDelete" disabled="{{loading}}">
    <text>确认注销账号</text>
  </view>
</view>