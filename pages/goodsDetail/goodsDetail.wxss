/* 全局页面背景：浅蓝色 */
page {
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
    background-attachment: fixed;
  }
  
  /* 加载 */
  .loading-overlay {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 9999;
    display: flex; align-items: center; justify-content: center;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
  }
  .loading-glass {
    padding: 50rpx 80rpx;
    border-radius: 20rpx;
    background: rgba(255,255,255,0.4);
    border: 1rpx solid rgba(255,255,255,0.5);
    backdrop-filter: blur(20px);
  }
  .loading-text {
    font-size: 32rpx;
    color: #2d8cf0;
  }
  
  /* 容器 */
  .container {
    padding: 20rpx;
    min-height: 100vh;
    box-sizing: border-box;
  }
  
  /* ========== 液态玻璃统一样式 ========== */
  .glass-bg {
    background: transparent !important;
  }
  .glass-card {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1rpx solid rgba(255,255,255,0.5);
    border-radius: 20rpx;
    margin-bottom: 24rpx;
    overflow: hidden;
  }
  .glass-float {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1rpx solid rgba(255,255,255,0.5);
  }
  
  /* 按钮统一玻璃效果 */
  .glass-btn {
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1rpx solid rgba(255,255,255,0.5);
    transition: all 0.2s ease;
  }
  .glass-btn:active {
    background: rgba(255,255,255,0.6);
  }
  
  /* 卖家信息 */
  .user-card {
    display: flex;
    align-items: center;
    padding: 24rpx 30rpx;
  }
  .avatar {
    width: 70rpx;
    height: 70rpx;
    border-radius: 50%;
    margin-right: 20rpx;
  }
  .nickname {
    font-size: 30rpx;
    color: #333;
  }
  .time {
    font-size: 24rpx;
    color: #666;
    margin-top: 6rpx;
  }
  
  /* 图片 */
  .img-wrap {
    padding: 10rpx;
  }
  .detail-img {
    width: 100%;
    height: 700rpx;
    border-radius: 16rpx;
  }
  
  /* 信息 */
  .info-wrap {
    padding: 30rpx;
  }
  .price {
    font-size: 42rpx;
    color: #fa5555;
    font-weight: bold;
  }
  .title {
    font-size: 34rpx;
    color: #333;
    margin: 10rpx 0 20rpx;
  }
  
  .tag-group {
    display: flex;
    gap: 16rpx;
  }
  .tag {
    padding: 8rpx 16rpx;
    border-radius: 30rpx;
    font-size: 24rpx;
    background: rgba(255,255,255,0.4);
    backdrop-filter: blur(10px);
  }
  .sale-tag.on {
    color: #00c48c;
  }
  .sale-tag.off {
    color: #fa5555;
  }
  .audit-tag {
    color: #2d8cf0;
  }
  
  /* 驳回 */
  .reject-wrap {
    padding: 30rpx;
    background: rgba(250, 85, 85, 0.1);
    border: 1rpx solid rgba(250, 85, 85, 0.25);
  }
  .reject-title {
    font-size: 30rpx;
    color: #fa5555;
    font-weight: bold;
    margin-bottom: 16rpx;
  }
  .reject-content {
    font-size: 28rpx;
    color: #666;
    line-height: 1.8;
  }
  
  /* 描述 */
  .desc-wrap {
    padding: 30rpx;
  }
  .desc-title {
    font-size: 30rpx;
    margin-bottom: 16rpx;
    color: #333;
  }
  .desc-content {
    font-size: 28rpx;
    color: #666;
    line-height: 1.8;
  }
  
  .placeholder {
    height: 120rpx;
  }
  
  /* 底部栏 */
  .footer-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100rpx;
    border-radius: 0;
    display: flex;
    align-items: center;
    padding: 0 30rpx;
    box-sizing: border-box;
    gap: 15rpx;
  }
  
  /* 按钮样式 */
  .collect-btn {
    width: 160rpx;
    height: 70rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 35rpx;
    color: #2d8cf0;
    font-size: 26rpx;
  }
  .buy-btn {
    flex: 1;
    height: 70rpx;
    color: #fff;
    text-align: center;
    line-height: 70rpx;
    border-radius: 35rpx;
    font-size: 28rpx;
    background: rgba(16, 125, 242, 0.35) !important;
    color: #fff !important;
    border-color: rgba(45,140,240,0.4);
  }
  .edit-info-btn {
    width: 150rpx;
    height: 70rpx;
    border-radius: 35rpx;
    color: #2d8cf0;
    text-align: center;
    line-height: 70rpx;
    font-size: 26rpx;
  }
  .status-btn {
    flex: 1;
    height: 70rpx;
    color: #fff;
    text-align: center;
    line-height: 70rpx;
    border-radius: 35rpx;
    font-size: 28rpx;
  }
  .status-btn.online {
    background: rgba(0, 196, 140, 0.35) !important;
    border-color: rgba(0,196,140,0.4);
  }
  .status-btn.offline {
    background: rgba(250,85,85,0.35) !important;
    border-color: rgba(250,85,85,0.4);
  }
  .reject-tip-btn {
    flex: 1;
    height: 70rpx;
    color: #fa5555;
    text-align: center;
    line-height: 70rpx;
    border-radius: 35rpx;
    font-size: 26rpx;
    font-weight: bold;
    background: rgba(250,85,85,0.15) !important;
  }
  .del-btn {
    width: 150rpx;
    height: 70rpx;
    color: #fa5555;
    text-align: center;
    line-height: 70rpx;
    border-radius: 35rpx;
    font-size: 26rpx;
  }
  .collect-btn.disabled {
    background: rgba(200,200,200,0.3) !important;
    color: #999 !important;
    pointer-events: none;
  }
  
  /* 删除提示 */
  .deleted-tip {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
    padding: 20rpx;
  }
  .deleted-box {
    width: 100%;
    padding: 80rpx 40rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20rpx;
  }
  .deleted-box .icon {
    font-size: 60rpx;
  }
  .deleted-box .text {
    font-size: 32rpx;
    color: #666;
  }