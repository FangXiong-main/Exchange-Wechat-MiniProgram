/* 全局玻璃样式 与项目保持一致 */
.glass-bg {
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    min-height: 100vh;
  }
  
  .glass-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 8px 32px rgba(100, 120, 200, 0.1);
    border-radius: 20rpx;
  }
  
  /* 页面整体布局 */
  .container {
    padding: 30rpx 20rpx;
    box-sizing: border-box;
  }
  
  /* 头部标题区域 */
  .header {
    padding: 35rpx 25rpx;
    text-align: center;
    margin-bottom: 30rpx;
  }
  
  .title {
    font-size: 40rpx;
    font-weight: bold;
    color: #2d8cf0;
    display: block;
    margin-bottom: 12rpx;
  }
  
  .sub-desc {
    font-size: 26rpx;
    color: #666;
  }
  
  /* 条款内容区域 */
  .content {
    padding: 30rpx 25rpx;
    line-height: 1.8;
  }
  
  .article .p {
    font-size: 28rpx;
    color: #333;
    display: block;
    margin-bottom: 20rpx;
    text-align: justify;
  }
  
  /* 底部落款 */
  .footer {
    margin-top: 60rpx;
    text-align: center;
    font-size: 28rpx;
    color: #666;
    padding-bottom: 40rpx;
  }