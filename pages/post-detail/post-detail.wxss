/* 全局 */
page {
    padding: 0;
    margin: 0;
    width: 100%;
    box-sizing: border-box;
  }
  
  /* 玻璃效果 */
  .glass-bg {
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
  }
  .glass-card {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(25px);
    border-radius: 20rpx;
  }
  .glass-input {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    border-radius: 35rpx;
  }
  
  /* 页面布局 */
  .container {
    height: 100vh;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    overflow: hidden;
  }
  
  /* 帖子卡片 */
  .detail-card {
    margin: 20rpx;
    padding: 30rpx;
    flex-shrink: 0;
    width: calc(100% - 40rpx);
    box-sizing: border-box;
  }
  
  .circle-user {
    display: flex;
    align-items: center;
  }
  .avatar {
    width: 70rpx;
    height: 70rpx;
    border-radius: 50%;
    margin-right: 20rpx;
  }

  /* 🔥 修复：用户名和时间拉开距离 */
  .user-info {
    display: flex;
    flex-direction: column;
    gap: 8rpx;
  }

  .nickname {
    font-size: 28rpx;
    color: #333;
  }
  .time {
    font-size: 22rpx;
    color: #999;
  }
  .circle-content {
    font-size: 28rpx;
    line-height: 1.5;
    margin: 20rpx 0;
  }
  .circle-img {
    width: 100%;
    border-radius: 16rpx;
  }
  .delete-wrapper {
    display: flex;
    justify-content: flex-end;
  }
  .del-btn {
    background: #ff4444;
    color: #fff;
    font-size: 20rpx;
    padding: 0 20rpx;
    height: 50rpx;
    line-height: 50rpx;
    border-radius: 25rpx;
  }
  
  /* 评论标题（固定） */
  .comment-title {
    font-size: 30rpx;
    font-weight: 500;
    padding: 0 20rpx 20rpx;
    flex-shrink: 0;
  }
  
  /* 评论区域（不超出屏幕） */
  .comment-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 0 20rpx;
    box-sizing: border-box;
    width: 100%;
  }
  
  /* 🔥 评论条：绝对不会超出屏幕 */
  .comment-item {
    display: flex;
    padding: 20rpx;
    margin-bottom: 15rpx;
    width: 100%;
    box-sizing: border-box;
  }
  
  .comment-right {
    flex: 1;
    margin-left: 15rpx;
  }
  .comment-top {
    display: flex;
    justify-content: space-between;
  }
  .name {
    font-size: 26rpx;
    color: #333;
  }
  .content {
    font-size: 26rpx;
    color: #333;
    line-height: 1.4;
    word-break: break-all;
  }
  
  .empty {
    text-align: center;
    color: #999;
    padding: 60rpx 0;
  }
  .load-tip {
    text-align: center;
    color: #999;
    padding: 20rpx 0;
  }
  
  /* 底部输入框 */
  .action-bar {
    width: 100%;
    padding: 20rpx;
    box-sizing: border-box;
    flex-shrink: 0;
  }
  .input-wrapper {
    display: flex;
    align-items: center;
    height: 70rpx;
    padding: 0 20rpx;
    box-sizing: border-box;
    width: 100%;
  }
  input {
    flex: 1;
    font-size: 26rpx;
  }
  .send-btn {
    background: #4080ff;
    color: #fff;
    padding: 0 24rpx;
    height: 50rpx;
    font-size: 25rpx;
    line-height: 50rpx;
    border-radius: 25rpx;
    margin-left: 12rpx;
  }
  .send-btn.disabled {
    background: #ccc;
  }
  
  /* 加载 */
  .full-loading {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
  }
  .loading-box {
    background: #000;
    color: #fff;
    padding: 20rpx 40rpx;
    border-radius: 12rpx;
  }