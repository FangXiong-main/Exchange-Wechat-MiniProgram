<!-- 上传loading -->
<view wx:if="{{uploadLoading}}" class="loading-overlay">
  <view class="loading-glass">
    <view class="loading-spinner"></view>
    <text class="loading-text">图片上传中...</text>
  </view>
</view>

<!-- 发布loading -->
<view wx:if="{{loading}}" class="loading-overlay">
  <view class="loading-glass">
    <view class="loading-spinner"></view>
    <text class="loading-text">发布中...</text>
  </view>
</view>

<view class="container glass-bg">
  <!-- 图片上传区域 -->
  <view class="img-section glass-card">
    <!-- 未上传状态 -->
    <view wx:if="{{!goodsImgShow}}" class="upload-placeholder" bindtap="uploadImage">
      <view class="upload-icon-circle">
        <text class="upload-icon">📷</text>
      </view>
      <text class="upload-hint">点击上传商品图片</text>
    </view>

    <!-- 已上传状态 -->
    <view wx:else class="img-preview-box">
      <image src="{{goodsImgShow}}" mode="aspectFill" class="preview-img" bindtap="previewImage"></image>
      <view class="preview-mask" bindtap="uploadImage">
        <text class="change-icon">🔄</text>
        <text class="change-text">更换图片</text>
      </view>
    </view>
  </view>

  <!-- 表单区域 -->
  <view class="form-list">
    <view class="form-item glass-card">
      <view class="form-label">
        <text class="label-icon">🏷️</text>
        <text>商品名称</text>
      </view>
      <input type="text" placeholder="请输入商品名称" class="form-input glass-input" value="{{goodsName}}" bindinput="onNameInput" />
    </view>

    <view class="form-item glass-card">
      <view class="form-label">
        <text class="label-icon">💰</text>
        <text>价格</text>
      </view>
      <view class="price-input-wrap">
        <text class="price-symbol">¥</text>
        <input type="number" placeholder="0.00" class="form-input glass-input" value="{{price}}" bindinput="onPriceInput" />
      </view>
    </view>

    <view class="form-item glass-card">
      <view class="form-label">
        <text class="label-icon">📦</text>
        <text>商品类型</text>
      </view>
      <picker value="{{typeIndex}}" range="{{typeList}}" bindchange="onTypeChange">
        <view class="form-input glass-input picker-display">
          <text>{{typeList[typeIndex]}}</text>
          <text class="arrow-icon">▼</text>
        </view>
      </picker>
    </view>

    <view class="form-item desc-wrap glass-card">
      <view class="form-label">
        <text class="label-icon">📝</text>
        <text>描述</text>
      </view>
      <textarea placeholder="请填写商品详细描述（500字以内）" class="desc-input glass-input" value="{{desc}}" bindinput="onDescInput" maxlength="500"></textarea>
      <text class="word-count">{{desc.length || 0}}/500</text>
    </view>
  </view>

  <!-- 发布按钮 -->
  <view class="submit-btn-wrap">
    <view class="submit-btn" bindtap="submitGoods">
      <text class="btn-text">✨ 发布商品</text>
    </view>
  </view>
</view>