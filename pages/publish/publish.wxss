/* ========== 加载弹窗 ========== */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.loading-glass {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 50rpx 80rpx;
  border-radius: 30rpx;
  background: rgba(255,255,255,0.35);
  border: 1px solid rgba(255,255,255,0.4);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  box-shadow: 0 16px 40px rgba(74, 123, 247, 0.15);
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid rgba(74,123,247,0.2);
  border-top-color: #4a7bf7;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #2d4b7a;
  font-weight: 600;
}

/* ========== 全局背景 ========== */
.glass-bg {
  background: linear-gradient(155deg, #eef6ff 0%, #f3f9ff 40%, #e8f4fd 100%);
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
}

.glass-card {
  background: rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8px 24px rgba(74, 123, 247, 0.08);
  border-radius: 24rpx;
  transition: all 0.25s ease;
}

.glass-input {
  background: rgba(255, 255, 255, 0.75) !important;
  backdrop-filter: blur(12px) !important;
  -webkit-backdrop-filter: blur(12px) !important;
  border: 1px solid rgba(255, 255, 255, 0.5) !important;
  border-radius: 16rpx !important;
  box-shadow: 0 2px 8px rgba(74, 123, 247, 0.04);
}

.container {
  padding: 0;
  box-sizing: border-box;
}

/* ========== 图片上传区 ========== */
.img-section {
  width: 100%;
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  position: relative;
  overflow: hidden;
}

/* ========== 未上传占位区域（全新设计） ========== */
.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 2rpx dashed rgba(74, 123, 247, 0.25);
  border-radius: 28rpx;
  transition: all 0.3s ease;
  box-shadow: 0 8px 24px rgba(74, 123, 247, 0.06);
}

.upload-placeholder:active {
  background: rgba(255, 255, 255, 0.65);
  border-color: #4a7bf7;
  transform: scale(0.98);
  box-shadow: 0 12px 32px rgba(74, 123, 247, 0.12);
}

/* 图标圆圈容器 */
.upload-icon-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(74, 123, 247, 0.12) 0%, rgba(120, 160, 255, 0.18) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 
    0 8px 20px rgba(74, 123, 247, 0.18),
    inset 0 2px 8px rgba(255, 255, 255, 0.6);
  position: relative;
}

/* 图标外圈光晕 */
.upload-icon-circle::after {
  content: '';
  position: absolute;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(74, 123, 247, 0.15);
  animation: iconPulse 2.5s ease-in-out infinite;
}

@keyframes iconPulse {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 0.9; transform: scale(1.06); }
}

/* 图标本身 */
.upload-icon {
  font-size: 52rpx;
  filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.1));
  z-index: 1;
}

/* 提示文字 */
.upload-hint {
  font-size: 28rpx;
  color: #4a7bf7;
  font-weight: 600;
  letter-spacing: 1rpx;
  margin-top: 4rpx;
}

/* 已上传预览 */
.img-preview-box {
  width: 100%;
  height: 100%;
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
}

.preview-img {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 24rpx;
}

.preview-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  backdrop-filter: blur(4px);
}

.change-icon {
  font-size: 28rpx;
}

.change-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
}

/* ========== 表单列表 ========== */
.form-list {
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-item {
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
}

.desc-wrap {
  flex-direction: column;
  align-items: flex-start;
  position: relative;
}

.form-label {
  width: 150rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #2d4b7a;
  font-weight: 600;
}

.label-icon {
  font-size: 32rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1e2b3c;
  padding: 16rpx 20rpx;
  height: auto;
  min-height: 72rpx;
  box-sizing: border-box;
}

.price-input-wrap {
  display: flex;
  align-items: center;
  flex: 1;
}

.price-symbol {
  font-size: 30rpx;
  font-weight: 600;
  color: #4a7bf7;
  margin-right: 10rpx;
}

.picker-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-right: 20rpx;
}

.arrow-icon {
  font-size: 24rpx;
  color: #8b9cb5;
}

/* 描述框 */
.desc-input {
  width: 100%;
  min-height: 140rpx;
  font-size: 28rpx;
  color: #1e2b3c;
  padding: 20rpx;
  border-radius: 16rpx;
  line-height: 1.6;
  margin-top: 12rpx;
  box-sizing: border-box;
  background: rgba(255,255,255,0.75);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.5);
}

.word-count {
  position: absolute;
  right: 30rpx;
  bottom: 20rpx;
  font-size: 22rpx;
  color: #8b9cb5;
  background: rgba(255,255,255,0.6);
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
}

/* ========== 发布按钮 ========== */
.submit-btn-wrap {
  margin-top: 40rpx;
  padding: 0 10rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #4a7bf7 0%, #6b9fff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12px 28px rgba(74, 123, 247, 0.25);
  transition: all 0.2s ease;
  border: 1px solid rgba(255,255,255,0.4);
}

.submit-btn:active {
  transform: scale(0.97);
  box-shadow: 0 6px 16px rgba(74, 123, 247, 0.2);
}

.btn-text {
  font-size: 34rpx;
  color: #fff;
  font-weight: 700;
  letter-spacing: 2rpx;
}