/* 全屏加载 */
.loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
}

.loading-glass {
    padding: 50rpx 80rpx;
    border-radius: 20rpx;
    background: rgba(255,255,255,0.25);
    border: 1px solid rgba(255,255,255,0.3);
}

.loading-text {
    font-size: 32rpx;
    color: #2d8cf0;
    font-weight: bold;
}

/* 全局样式 */
.glass-bg {
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
    backdrop-filter: blur(20px);
    min-height: 100vh;
}

.glass-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 20rpx;
}

.glass-btn {
    background: rgba(102, 175, 239, 0.3);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #2d8cf0 !important;
}

.save-btn[disabled] {
    opacity: 0.5;
}

.container {
    padding: 20rpx;
    box-sizing: border-box;
}

/* 标题 */
.title-box {
    margin: 80rpx 0 40rpx;
    text-align: center;
}

.main-title {
    display: block;
    font-size: 46rpx;
    font-weight: bold;
    color: #2d8cf0;
    margin-bottom: 16rpx;
}

.sub-title {
    font-size: 28rpx;
    color: #666;
}

/* 提示卡片 */
.tip-card {
    padding: 24rpx 30rpx;
    margin-bottom: 30rpx;
    background: rgba(255, 193, 7, 0.1);
    border: 1px solid rgba(255, 193, 7, 0.3);
}

.tip-text {
    font-size: 26rpx;
    color: #e6a700;
    line-height: 1.6;
}

/* 表单 */
.form-box {
    padding: 10rpx 30rpx;
    margin-bottom: 40rpx;
}

.input-item {
    padding: 24rpx 0;
    border-bottom: 1rpx solid rgba(100, 120, 200, 0.1);
}

.picker-item {
    cursor: pointer;
}

.picker-placeholder {
    font-size: 28rpx;
    color: #999;
}

.picker-placeholder.active {
    color: #333;
}

/* 保存按钮 */
.save-btn {
    text-align: center;
    padding: 28rpx 0;
    font-size: 32rpx;
    font-weight: bold;
    border-radius: 20rpx;
    margin-top: 20rpx;
}