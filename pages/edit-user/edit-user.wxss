/* 全屏加载 */
.loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
  }
  
  .loading-glass {
    padding: 50rpx 80rpx;
    border-radius: 20rpx;
    background: rgba(255,255,255,0.25);
    border: 1px solid rgba(255,255,255,0.3);
  }
  
  .loading-text {
    font-size: 32rpx;
    color: #2d8cf0;
    font-weight: bold;
  }
  
  /* 页面风格 */
  .container {
    padding: 20rpx;
    min-height: 100vh;
    box-sizing: border-box;
  }
  
  .glass-bg {
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
    backdrop-filter: blur(20px);
  }
  
  .glass-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 8rpx 32rpx rgba(100, 120, 200, 0.1);
    border-radius: 20rpx;
  }
  
  .glass-btn {
    background: rgba(102, 175, 239, 0.35);
    backdrop-filter: blur(18px);
    border: 1px solid rgba(255,255,255,0.3);
  }
  
  /* 标题 */
  .page-title {
    font-size: 36rpx;
    font-weight: bold;
    color: #2d8cf0;
    margin: 40rpx 0 30rpx;
    text-align: center;
  }
  
  /* 提示卡片 */
  .warn-card {
    padding: 24rpx 30rpx;
    margin-bottom: 30rpx;
    background: rgba(255, 193, 7, 0.08);
    border: 1rpx solid rgba(255, 193, 7, 0.2);
  }
  
  .warn-text {
    display: block;
    font-size: 26rpx;
    color: #e6a700;
    line-height: 1.6;
    margin-bottom: 8rpx;
  }
  
  /* 表单 */
  .card {
    padding: 30rpx;
    margin-bottom: 40rpx;
  }
  
  .item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24rpx 0;
    border-bottom: 1rpx solid rgba(100, 120, 200, 0.1);
  }
  
  .item:last-child {
    border-bottom: none;
  }
  
  .label {
    font-size: 28rpx;
    color: #333;
    width: 140rpx;
  }
  
  .input {
    flex: 1;
    font-size: 28rpx;
    color: #333;
    text-align: right;
  }
  
  /* 头像 */
  .avatar-row {
    display: flex;
    align-items: center;
  }
  
  .avatar {
    width: 80rpx;
    height: 80rpx;
    border-radius: 50%;
    object-fit: cover;
  }
  
  .tip {
    font-size: 24rpx;
    color: #999;
    margin-left: 16rpx;
  }
  
  /* 保存按钮 */
  .save-btn {
    height: 88rpx;
    border-radius: 44rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 40rpx;
  }
  
  .save-text {
    color: #2d8cf0;
    font-size: 30rpx;
    font-weight: bold;
  }

  .picker-text {
    color: #333 !important;
    text-align: right;
  }