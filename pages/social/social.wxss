/* ====================== 统一液态玻璃 + 浅蓝色背景 ====================== */
.glass-bg {
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f9ff 100%);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    min-height: 100vh;
    padding-bottom: 120rpx;
  }
  
  .glass-float {
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    box-shadow: 0 8px 32px rgba(100, 120, 200, 0.12);
  }
  
  .glass-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 8px 32px rgba(100, 120, 200, 0.1);
    border-radius: 20rpx;
  }
  
  .glass-input {
    background: rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.4);
  }
  
  .glass-btn {
    background: rgba(102, 175, 239, 0.3);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #2d8cf0 !important;
  }
  
  /* ====================== 页面样式 ====================== */
  .container {
    padding: 20rpx;
    box-sizing: border-box;
  }
  
  .header-filter {
    position: sticky;
    top: 0;
    z-index: 99;
    display: flex;
    align-items: center;
    gap: 15rpx;
    padding: 20rpx;
    border-radius: 0 0 20rpx 20rpx;
  }
  
  .search-box {
    flex: 1;
    display: flex;
    align-items: center;
    height: 70rpx;
    border-radius: 35rpx;
    padding: 0 20rpx;
  }
  
  .search-icon {
    margin-right: 12rpx;
  }
  
  .search-input {
    flex: 1;
    font-size: 26rpx;
    color: #333;
  }
  
  .search-btn {
    padding: 0 25rpx;
    height: 50rpx;
    line-height: 50rpx;
    border-radius: 25rpx;
    font-size: 24rpx;
    margin-left: 12rpx;
    text-align: center;
  }
  
  .filter-wrap {
    display: flex;
    align-items: center;
    gap: 8rpx;
    padding: 12rpx 16rpx;
    border-radius: 30rpx;
    white-space: nowrap;
  }
  
  .filter-text {
    font-size: 24rpx;
    color: #333;
  }
  
  .circle-list {
    margin-top: 20rpx;
  }
  
  .circle-item {
    padding: 30rpx;
    margin-bottom: 20rpx;
  }
  
  .circle-user {
    display: flex;
    align-items: center;
    margin-bottom: 20rpx;
  }
  
  .avatar {
    width: 70rpx;
    height: 70rpx;
    border-radius: 50%;
    margin-right: 20rpx;
  }
  
  .user-info {
    display: flex;
    flex-direction: column;
  }
  
  .nickname {
    font-size: 28rpx;
    color: #333;
    font-weight: 500;
  }
  
  .time {
    font-size: 22rpx;
    color: #999;
    margin-top: 6rpx;
  }
  
  .circle-content {
    font-size: 28rpx;
    color: #333;
    line-height: 1.5;
    margin-bottom: 20rpx;
  }
  
  .circle-img {
    width: 100%;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
  }
  
  .circle-action {
    display: flex;
    gap: 40rpx;
    font-size: 24rpx;
    color: #666;
  }
  
  /* 发布按钮 → ✅ 这里修复 z-index，不挡住点击！！！ */
  .publish-btn {
    position: fixed;
    right: 40rpx;
    bottom: 120rpx;
    width: 100rpx;
    height: 100rpx;
    background: #4080ff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 60rpx;
    box-shadow: 0 6px 20px rgba(64, 128, 255, 0.4);
    z-index: 9; /* ✅ 改小！不要盖住列表！ */
  }
  
  /* 加载中样式 */
  .loading-mask {
    position: fixed;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
  }
  .loading-box {
    background: rgba(0,0,0,0.7);
    color: #fff;
    font-size: 28rpx;
    padding: 20rpx 40rpx;
    border-radius: 10rpx;
  }